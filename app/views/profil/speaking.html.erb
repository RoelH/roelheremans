<% content_for :head do %>
  <% if @speaking.seo_title.present? %>
    <title><%= @speaking.seo_title %></title>
  <% end %>
  <% if @speaking.seo_description.present? %>
    <meta name="description" content="<%= @speaking.seo_description %>">
  <% end %>
<% end %>

<div class="flex">
  <div class="scroll">
      <%= render 'shared/list'%>
  </div>
  <div class="show">
    <div class="container">
      <div class="work">
      <div class="entete"><h1>Speaking</h1></div>
        <div class="image">
          <%= image_tag @speaking.pic_url if @speaking.pic_url.present? %>
        </div>
        <div class="paragraph">
        <%= simple_format(@speaking.text) %>
        </div>
      </div>
    </div>
  </div>
</div>
